{
  "fetchCustomers": {
    "schema": {
      "protocol": "https",
      "method": "GET",
      "host": "<%= iparam.shopify_subdomain %>.myshopify.com",
      "path": "/admin/api/2023-04/customers.json",
      "query": {
        "limit": "<%= context.limit %>",
        "since_id": "<%= context.since_id %>"
      },
      "headers": {
        "X-Shopify-Access-Token": "<%= iparam.shopify_access_token %>",
        "Content-Type": "application/json"
      }
    }
  },
  "searchCustomers": {
    "schema": {
      "protocol": "https",
      "method": "GET",
      "host": "<%= iparam.shopify_subdomain %>.myshopify.com",
      "path": "/admin/api/2023-04/customers/search.json",
      "query": {
        "query": "<%= context.query %>"
      },
      "headers": {
        "X-Shopify-Access-Token": "<%= iparam.shopify_access_token %>",
        "Content-Type": "application/json"
      }
    }
  },
  "fetchCustomerOrders": {
    "schema": {
      "protocol": "https",
      "method": "GET",
      "host": "<%= iparam.shopify_subdomain %>.myshopify.com",
      "path": "/admin/api/2023-04/orders.json",
      "query": {
        "email": "<%= context.customer_email %>",
        "status": "any",
        "limit": "<%= context.limit %>"
      },
      "headers": {
        "Content-Type": "application/json",
        "X-Shopify-Access-Token": "<%= iparam.shopify_access_token %>"
      }
    }
  },
  "fetchOrders": {
    "schema": {
      "protocol": "https",
      "method": "GET",
      "host": "<%= iparam.shopify_subdomain %>.myshopify.com",
      "path": "/admin/api/2023-04/orders.json",
      "query": {
        "limit": "<%= context.limit %>",
        "since_id": "<%= context.since_id %>",
        "status": "any"
      },
      "headers": {
        "Content-Type": "application/json",
        "X-Shopify-Access-Token": "<%= iparam.shopify_access_token %>"
      }
    }
  },
  "fetchOrderById": {
    "schema": {
      "protocol": "https",
      "method": "GET",
      "host": "<%= iparam.shopify_subdomain %>.myshopify.com",
      "path": "/admin/api/2023-04/orders/<%= context.order_id %>.json",
      "headers": {
        "Content-Type": "application/json",
        "X-Shopify-Access-Token": "<%= iparam.shopify_access_token %>"
      }
    }
  }
}
